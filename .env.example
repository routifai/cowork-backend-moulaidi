# hypatia-backend — standalone dev config
#
# Only needed if you run `pnpm run dev` directly in THIS repo, without the
# Tauri shell (hypatia-frontend). When run through the full desktop app,
# these are injected by the Rust shell from hypatia-frontend's own .env
# instead — don't duplicate secrets in both places for real use.
#
# Copy this to .env (gitignored) and fill in your key.

# Embedded Anthropic API key. The engine boots fine without it; prompts just
# fail cleanly until it's set.
ANTHROPIC_API_KEY=

# Log verbosity: error/warn/info/debug
SIDECAR_LOG_LEVEL=info
